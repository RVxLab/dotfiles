#!/usr/bin/env bash

set -euo pipefail

# Ask for sudo password if not root
if [[ "$(whoami)" != "root" ]]
then
    sudo echo "sudo password successful, continuing"
fi

MACOS_TAR_SRC="https://github.com/neovim/neovim/releases/download/nightly/nvim-macos.tar.gz"
MACOS_TAR_DEST_DIR="/tmp"
MACOS_TAR_DEST="$MACOS_TAR_DEST_DIR/nvim-macos-nightly.tar.gz"
MACOS_TAR_SHA_SRC="https://github.com/neovim/neovim/releases/download/nightly/nvim-macos.tar.gz.sha256sum"
MACOS_NVIM_DIR="nvim-macos"
MACOS_NVIM_INSTALL_BASE_DIR="/opt/$(whoami)"
MACOS_NVIM_INSTALL_DIR="$MACOS_NVIM_INSTALL_BASE_DIR/$MACOS_NVIM_DIR"
MACOS_NVIM_SYMLINK_SRC="$MACOS_NVIM_INSTALL_DIR/bin/nvim"
MACOS_NVIM_SYMLINK="/usr/local/bin/nvim"

echo "Downloading nightly Neovim tar"
curl -sLfo "$MACOS_TAR_DEST" "$MACOS_TAR_SRC"

echo "Downloading nightly Neovim tar SHA"
EXPECTED_SHA="$(curl -sLf "$MACOS_TAR_SHA_SRC" | awk '{ print $1 }')"

echo "Checking if tar can provide the correct SHA hash..."
ACTUAL_SHA="$(shasum -a 256 "$MACOS_TAR_DEST" | awk '{ print $1 }')"

if [[ "$ACTUAL_SHA" == "$EXPECTED_SHA" ]]
then
    echo "...valid, unpacking and installing"

    if [[ ! -d "$MACOS_NVIM_INSTALL_BASE_DIR" ]]
    then
        OWNER="$(id -u)"
        GROUP="$(id -g)"

        echo "Base dir, does not exist, creating with owner $OWNER and group $GROUP..."
        sudo mkdir "$MACOS_NVIM_INSTALL_BASE_DIR"
        sudo chown "$OWNER:$GROUP" "$MACOS_NVIM_INSTALL_BASE_DIR"

        echo "...created, verifying it exists..."
        if ! stat "$MACOS_NVIM_INSTALL_BASE_DIR"
        then
            echo "...not created, manually create '$MACOS_NVIM_INSTALL_BASE_DIR' with owner $OWNER and group $GROUP, then rerun this script." 
            exit 99
        fi

        echo "...verified!"
    fi

    mkdir -p "$MACOS_NVIM_INSTALL_DIR-new"

    if ! tar -xzf "$MACOS_TAR_DEST" -C "$MACOS_NVIM_INSTALL_DIR-new"
    then
        echo "Failed to unpack, exiting"

        exit 1
    fi

    if [[ -d "$MACOS_NVIM_INSTALL_DIR" ]]
    then
        echo "Backing up old version"

        if ! mv "$MACOS_NVIM_INSTALL_DIR" "$MACOS_NVIM_INSTALL_DIR-old"
        then
            echo "Failed to back up old version, exiting"
            rm -rf "$MACOS_NVIM_INSTALL_DIR-new"
            exit 2
        fi
    fi

    echo "Placing new version"

    if ! mv "$MACOS_NVIM_INSTALL_DIR-new/nvim-macos" "$MACOS_NVIM_INSTALL_DIR"
    then
        echo "Failed to place new version, exiting"
        mv "$MACOS_NVIM_INSTALL_DIR-old" "$MACOS_NVIM_INSTALL_DIR"
        rm -rf "$MACOS_NVIM_INSTALL_DIR-new"
        exit 3
    fi

    if [[ ! -f "$MACOS_NVIM_SYMLINK" ]]
    then
        echo "Creating symlink $MACOS_NVIM_SYMLINK -> $MACOS_NVIM_SYMLINK_SRC"
        sudo ln -s "$MACOS_NVIM_SYMLINK_SRC" "$MACOS_NVIM_SYMLINK"
    fi

    echo "Neovim has been installed, checking version to see if installation was successful"

    if ! nvim -v
    then
        echo "Failed to install, reverting to old version and exiting"
        mv "$MACOS_NVIM_INSTALL_DIR-old" "$MACOS_NVIM_INSTALL_DIR"
        rm -rf "$MACOS_NVIM_INSTALL_DIR-new"
        exit 4
    fi

    echo "Successful, removing old version"

    rm -rf "$MACOS_NVIM_INSTALL_DIR-old"
    rmdir "$MACOS_NVIM_INSTALL_DIR-new"
else
    echo "...failed to verify the tar is valid"
fi

echo "Cleaning up"
rm "$MACOS_TAR_DEST"

